        "import pickle\n",
        "import os\n",
        "\n",
        "# Créer un dossier pour les modèles\n",
        "os.makedirs('models', exist_ok=True)\n",
        "\n",
        "# Sauvegarder chaque modèle\n",
        "for q in range(1, 11):\n",
        "    torch.save(models[q].state_dict(), f'models/model_q{q}.pth')\n",
        "\n",
        "# Métadonnées globales\n",
        "metadata = {\n",
        "    'sbert_model_name': 'all-mpnet-base-v2',\n",
        "    'global_results': {\n",
        "        'qwk': global_qwk,\n",
        "        'accuracy': global_accuracy\n",
        "    },\n",
        "    'question_results': results_df.to_dict('records'),\n",
        "    'hyperparams': hyperparams,\n",
        "    'feature_scaler': scaler,\n",
        "    'feature_cols': feature_cols\n",
        "}\n",
        "\n",
        "with open('models/metadata.pkl', 'wb') as f:\n",
        "    pickle.dump(metadata, f)\n",
        "\n",
        "print(\"✅ Modèles sauvegardés dans le dossier 'models/'\")\n",
        "print(\"\\nFichiers créés:\")\n",
        "for q in range(1, 11):\n",
        "    print(f\"   - model_q{q}.pth\")\n",
        "print(\"   - metadata.pkl\")\n",
        "\n",
        "# Télécharger depuis Colab\n",
        "from google.colab import files\n",
        "import shutil\n",
        "\n",
        "# Créer une archive\n",
        "shutil.make_archive('asap_models_improved', 'zip', 'models')\n",
        "files.download('asap_models_improved.zip')\n",
        "\n",
        "print(\"\\n✅ Archive téléchargée: asap_models_improved.zip\")"
