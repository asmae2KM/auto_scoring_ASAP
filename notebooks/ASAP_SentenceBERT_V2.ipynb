        "# Préparation des données pour chaque question\n",
        "question_data = {}\n",
        "\n",
        "for q in range(1, 11):\n",
        "    print(f\"\\n📊 Préparation Question {q}\")\n",
        "    print(\"=\"*60)\n",
        "\n",
        "    # Filtrage des données\n",
        "    q_mask = df['EssaySet'] == q\n",
        "    X_q = X_combined[q_mask]\n",
        "    y_q = df[q_mask]['Score1'].values\n",
        "\n",
        "    # Classes disponibles\n",
        "    unique_classes = np.unique(y_q)\n",
        "    n_classes = len(unique_classes)\n",
        "\n",
        "    print(f\"Samples: {len(X_q)} | Classes: {n_classes} | Distribution: {Counter(y_q)}\")\n",
        "\n",
        "    # Split train/test stratifié\n",
        "    X_train, X_test, y_train, y_test = train_test_split(\n",
        "        X_q, y_q,\n",
        "        test_size=0.15,\n",
        "        stratify=y_q,\n",
        "        random_state=42\n",
        "    )\n",
        "\n",
        "    # Augmentation spécifique pour Question 3\n",
        "    if q == 3:\n",
        "        print(\"\\n🔄 Application d'augmentation pour Question 3...\")\n",
        "\n",
        "        # Identifier les classes minoritaires\n",
        "        class_counts = Counter(y_train)\n",
        "        max_count = max(class_counts.values())\n",
        "\n",
        "        X_aug_list = [X_train]\n",
        "        y_aug_list = [y_train]\n",
        "\n",
        "        for cls in unique_classes:\n",
        "            if class_counts[cls] < max_count * 0.7:  # Si moins de 70% de la classe majoritaire\n",
        "                n_to_generate = int((max_count * 0.7 - class_counts[cls]) * 1.5)\n",
        "                X_new, y_new = augment_embeddings(X_train, y_train, cls, n_samples=n_to_generate)\n",
        "\n",
        "                if len(X_new) > 0:\n",
        "                    X_aug_list.append(X_new)\n",
        "                    y_aug_list.append(y_new)\n",
        "                    print(f\"   Classe {cls}: +{len(X_new)} échantillons synthétiques\")\n",
        "\n",
        "        X_train = np.vstack(X_aug_list)\n",
        "        y_train = np.concatenate(y_aug_list)\n",
        "\n",
        "        print(f\"   Total après augmentation: {len(X_train)} échantillons\")\n",
        "        print(f\"   Nouvelle distribution: {Counter(y_train)}\")\n",
        "\n",
        "    # Calcul des poids de classe\n",
        "    class_weights = compute_class_weight(\n",
        "        class_weight='balanced',\n",
        "        classes=unique_classes,\n",
        "        y=y_train\n",
        "    )\n",
        "    class_weights_dict = {cls: weight for cls, weight in zip(unique_classes, class_weights)}\n",
        "\n",
        "    # Stockage\n",
        "    question_data[q] = {\n",
        "        'X_train': X_train,\n",
        "        'X_test': X_test,\n",
        "        'y_train': y_train,\n",
        "        'y_test': y_test,\n",
        "        'n_classes': n_classes,\n",
        "        'unique_classes': unique_classes,\n",
        "        'class_weights': class_weights_dict\n",
        "    }\n",
        "\n",
        "print(\"\\n✅ Préparation terminée pour toutes les questions\")"
      ]
