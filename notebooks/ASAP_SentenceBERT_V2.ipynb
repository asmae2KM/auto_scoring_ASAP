        "---\n",
        "## 4. Prétraitement des Textes"
      ]
    },
    {
      "cell_type": "code",
      "execution_count": 7,
      "metadata": {
        "colab": {
          "base_uri": "https://localhost:8080/"
        },
        "id": "gId7pI95-k9N",
        "outputId": "6730af67-478e-4403-c282-6d8fdbc90a1c"
      },
      "outputs": [
        {
          "output_type": "stream",
          "name": "stdout",
          "text": [
            "✅ Dataset après nettoyage: 17207 réponses\n"
          ]
        }
      ],
      "source": [
        "def clean_text(text):\n",
        "    \"\"\"Nettoyage du texte\"\"\"\n",
        "    if pd.isna(text):\n",
        "        return \"\"\n",
        "    text = str(text)\n",
        "    text = re.sub(r'\\s+', ' ', text)  # Espaces multiples\n",
        "    text = text.strip()\n",
        "    return text\n",
        "\n",
        "# Application du nettoyage\n",
        "df['EssayText_clean'] = df['EssayText'].apply(clean_text)\n",
        "\n",
        "# Suppression des réponses vides\n",
        "df = df[df['EssayText_clean'].str.len() > 0].reset_index(drop=True)\n",
        "print(f\"✅ Dataset après nettoyage: {len(df)} réponses\")"
      ]
    },
    {
      "cell_type": "markdown",
      "metadata": {
        "id": "4Ce6MKm_-k9N"
      },
      "source": [
        "---\n",
        "## 5. Feature Engineering Avancé"
      ]
    },
    {
      "cell_type": "code",
      "execution_count": 8,
      "metadata": {
        "colab": {
          "base_uri": "https://localhost:8080/"
        },
        "id": "WbKY98X1-k9N",
        "outputId": "1d79f5f1-9c1c-475b-9a00-58c15eee5f67"
      },
      "outputs": [
        {
          "output_type": "stream",
          "name": "stdout",
          "text": [
            "✅ Features textuelles extraites:\n",
            "         word_count    char_count  avg_word_length  sentence_count  \\\n",
            "count  17207.000000  17207.000000     17207.000000    17207.000000   \n",
            "mean      42.354391    236.070320         4.934974        2.890161   \n",
            "std       27.197818    150.175588         2.387208        2.036292   \n",
            "min        1.000000      1.000000         1.000000        1.000000   \n",
            "25%       23.000000    128.000000         4.254902        1.000000   \n",
            "50%       39.000000    218.000000         4.594203        2.000000   \n",
            "75%       56.000000    318.000000         5.000000        4.000000   \n",
            "max      325.000000   1800.000000        56.500000       28.000000   \n",
            "\n",
            "       unique_word_ratio  \n",
            "count       17207.000000  \n",
            "mean            0.808567  \n",
            "std             0.111945  \n",
            "min             0.407407  \n",
            "25%             0.729730  \n",
            "50%             0.803279  \n",
            "75%             0.885714  \n",
            "max             1.000000  \n"
          ]
        }
      ],
      "source": [
        "def extract_text_features(text):\n",
        "    \"\"\"Extraction de features textuelles\"\"\"\n",
        "    words = text.split()\n",
        "    sentences = text.split('.')\n",
        "\n",
        "    return {\n",
        "        'word_count': len(words),\n",
        "        'char_count': len(text),\n",
        "        'avg_word_length': np.mean([len(w) for w in words]) if words else 0,\n",
        "        'sentence_count': len([s for s in sentences if s.strip()]),\n",
        "        'unique_word_ratio': len(set(words)) / len(words) if words else 0,\n",
        "    }\n",
        "\n",
        "# Application\n",
        "features_df = df['EssayText_clean'].apply(extract_text_features).apply(pd.Series)\n",
        "df = pd.concat([df, features_df], axis=1)\n",
        "\n",
        "print(\"✅ Features textuelles extraites:\")\n",
        "print(features_df.describe())"
      ]
    },
