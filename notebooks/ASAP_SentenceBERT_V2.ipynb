      "source": [
        "# Hyperparamètres par question\n",
        "hyperparams = {\n",
        "    1: {'lr': 0.001, 'dropout': 0.4, 'epochs': 100, 'batch_size': 32, 'label_smoothing': 0.1},\n",
        "    2: {'lr': 0.001, 'dropout': 0.4, 'epochs': 100, 'batch_size': 32, 'label_smoothing': 0.1},\n",
        "    3: {'lr': 0.0005, 'dropout': 0.5, 'epochs': 150, 'batch_size': 16, 'label_smoothing': 0.15},  # Spécial Q3\n",
        "    4: {'lr': 0.001, 'dropout': 0.3, 'epochs': 100, 'batch_size': 32, 'label_smoothing': 0.1},\n",
        "    5: {'lr': 0.001, 'dropout': 0.3, 'epochs': 100, 'batch_size': 32, 'label_smoothing': 0.1},\n",
        "    6: {'lr': 0.001, 'dropout': 0.3, 'epochs': 100, 'batch_size': 32, 'label_smoothing': 0.1},\n",
        "    7: {'lr': 0.001, 'dropout': 0.4, 'epochs': 100, 'batch_size': 32, 'label_smoothing': 0.1},\n",
        "    8: {'lr': 0.001, 'dropout': 0.4, 'epochs': 100, 'batch_size': 32, 'label_smoothing': 0.1},\n",
        "    9: {'lr': 0.001, 'dropout': 0.4, 'epochs': 100, 'batch_size': 32, 'label_smoothing': 0.1},\n",
        "    10: {'lr': 0.001, 'dropout': 0.4, 'epochs': 100, 'batch_size': 32, 'label_smoothing': 0.1},\n",
        "}\n",
        "\n",
        "# Stockage des résultats\n",
        "models = {}\n",
        "results = {}\n",
        "histories = {}\n",
        "\n",
        "# Entraînement pour chaque question\n",
        "for q in range(1, 11):\n",
        "    print(f\"\\n{'='*80}\")\n",
        "    print(f\"🎯 ENTRAÎNEMENT - QUESTION {q}\")\n",
        "    print(f\"{'='*80}\")\n",
        "\n",
        "    # Récupération des données\n",
        "    data = question_data[q]\n",
        "    X_train, X_test = data['X_train'], data['X_test']\n",
        "    y_train, y_test = data['y_train'], data['y_test']\n",
        "    n_classes = data['n_classes']\n",
        "    class_weights = data['class_weights']\n",
        "\n",
        "    # Hyperparamètres\n",
        "    hp = hyperparams[q]\n",
        "\n",
        "    print(f\"\\nConfiguration:\")\n",
        "    print(f\"  - Train samples: {len(X_train)}\")\n",
        "    print(f\"  - Test samples: {len(X_test)}\")\n",
        "    print(f\"  - Classes: {n_classes}\")\n",
        "    print(f\"  - Learning rate: {hp['lr']}\")\n",
        "    print(f\"  - Dropout: {hp['dropout']}\")\n",
        "    print(f\"  - Epochs: {hp['epochs']}\")\n",
        "    print(f\"  - Batch size: {hp['batch_size']}\")\n",
        "    print(f\"  - Label smoothing: {hp['label_smoothing']}\")\n",
        "\n",
        "    # Datasets et Loaders\n",
        "    train_dataset = TextDataset(X_train, y_train)\n",
        "    test_dataset = TextDataset(X_test, y_test)\n",
        "\n",
        "    train_loader = DataLoader(train_dataset, batch_size=hp['batch_size'], shuffle=True)\n",
        "    test_loader = DataLoader(test_dataset, batch_size=hp['batch_size'], shuffle=False)\n",
        "\n",
        "    # Modèle\n",
        "    model = ImprovedMLP(\n",
        "        input_dim=X_train.shape[1],\n",
        "        num_classes=n_classes,\n",
        "        dropout_rate=hp['dropout'],\n",
        "        use_residual=True\n",
        "    ).to(device)\n",
        "\n",
        "    # Loss avec poids de classe\n",
        "    weight_tensor = torch.FloatTensor([class_weights[i] for i in range(n_classes)]).to(device)\n",
        "    criterion = LabelSmoothingCrossEntropy(epsilon=hp['label_smoothing'], weight=weight_tensor)\n",
        "\n",
        "    # Optimizer\n",
        "    optimizer = optim.AdamW(model.parameters(), lr=hp['lr'], weight_decay=0.01)\n",
        "\n",
        "    # Scheduler\n",
        "    total_steps = len(train_loader) * hp['epochs']\n",
        "    scheduler = OneCycleLR(\n",
        "        optimizer,\n",
        "        max_lr=hp['lr'],\n",
        "        total_steps=total_steps,\n",
        "        pct_start=0.1,\n",
        "        anneal_strategy='cos'\n",
        "    )\n",
        "\n",
        "    # Entraînement\n",
        "    history = {\n",
        "        'train_loss': [], 'train_acc': [], 'train_qwk': [],\n",
        "        'val_acc': [], 'val_qwk': []\n",
        "    }\n",
        "\n",
        "    best_qwk = -1\n",
        "    best_model_state = None\n",
        "    patience_counter = 0\n",
        "    patience = 20\n",
        "\n",
        "    print(\"\\n🚀 Début de l'entraînement...\\n\")\n",
        "\n",
        "    for epoch in range(hp['epochs']):\n",
        "        # Train\n",
        "        train_loss, train_acc, train_qwk = train_epoch(\n",
        "            model, train_loader, criterion, optimizer, scheduler, device\n",
        "        )\n",
        "\n",
        "        # Validation\n",
        "        _, _, val_acc, val_qwk = evaluate(model, test_loader, device)\n",
        "\n",
        "        # Historique\n",
        "        history['train_loss'].append(train_loss)\n",
        "        history['train_acc'].append(train_acc)\n",
        "        history['train_qwk'].append(train_qwk)\n",
        "        history['val_acc'].append(val_acc)\n",
        "        history['val_qwk'].append(val_qwk)\n",
        "\n",
        "        # Affichage périodique\n",
        "        if (epoch + 1) % 10 == 0 or epoch == 0:\n",
        "            print(f\"Epoch {epoch+1:3d}/{hp['epochs']} | \"\n",
        "                  f\"Loss: {train_loss:.4f} | \"\n",
        "                  f\"Train QWK: {train_qwk:.4f} | \"\n",
        "                  f\"Val QWK: {val_qwk:.4f} | \"\n",
        "                  f\"Val Acc: {val_acc:.4f}\")\n",
        "\n",
        "        # Early stopping basé sur QWK\n",
        "        if val_qwk > best_qwk:\n",
        "            best_qwk = val_qwk\n",
        "            best_model_state = model.state_dict().copy()\n",
        "            patience_counter = 0\n",
        "        else:\n",
        "            patience_counter += 1\n",
        "\n",
        "        if patience_counter >= patience:\n",
        "            print(f\"\\n⏹️ Early stopping à l'epoch {epoch+1}\")\n",
        "            break\n",
        "\n",
        "    # Charger le meilleur modèle\n",
        "    model.load_state_dict(best_model_state)\n",
        "\n",
        "    # Évaluation finale\n",
        "    y_pred, y_true, test_acc, test_qwk = evaluate(model, test_loader, device)\n",
        "\n",
        "    print(f\"\\n✅ Meilleurs résultats:\")\n",
        "    print(f\"   - Test Accuracy: {test_acc:.4f}\")\n",
        "    print(f\"   - Test QWK: {test_qwk:.4f}\")\n",
        "\n",
        "    # Stockage\n",
        "    models[q] = model\n",
        "    results[q] = {\n",
        "        'y_pred': y_pred,\n",
        "        'y_true': y_true,\n",
        "        'accuracy': test_acc,\n",
        "        'qwk': test_qwk,\n",
        "        'n_samples': len(y_test)\n",
        "    }\n",
        "    histories[q] = history\n",
        "\n",
        "print(\"\\n\" + \"=\"*80)\n",
        "print(\"✅ ENTRAÎNEMENT TERMINÉ POUR TOUTES LES QUESTIONS\")\n",
        "print(\"=\"*80)"
      ]
    },
