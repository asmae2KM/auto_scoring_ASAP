      "source": [
        "# QWK entre Score1 et Score2\n",
        "def quadratic_weighted_kappa(y_true, y_pred):\n",
        "    return cohen_kappa_score(y_true, y_pred, weights='quadratic')\n",
        "\n",
        "qwk_inter = quadratic_weighted_kappa(df['Score1'], df['Score2'])\n",
        "print(f\"✅ QWK entre Score1 et Score2: {qwk_inter:.3f}\")\n",
        "print(\"   (Un QWK proche de 1 indique un accord élevé entre évaluateurs)\\n\")\n",
        "\n",
        "# Distribution des questions\n",
        "print(\"📊 Distribution par question:\")\n",
        "print(df['EssaySet'].value_counts().sort_index())\n",
        "\n",
        "# Analyse détaillée par question\n",
        "print(\"\\n📊 Analyse par question:\")\n",
        "print(\"=\"*80)\n",
        "for q in range(1, 11):\n",
        "    q_data = df[df['EssaySet'] == q]\n",
        "    scores = q_data['Score1'].value_counts().sort_index()\n",
        "    n_classes = len(scores)\n",
        "    print(f\"Question {q:2d}: {len(q_data):4d} réponses | {n_classes} classes | Scores: {scores.index.tolist()}\")\n",
        "    print(f\"            Distribution: {dict(scores)}\")"
      ]
