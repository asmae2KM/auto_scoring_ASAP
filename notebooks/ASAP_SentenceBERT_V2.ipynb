      "source": [
        "def augment_embeddings(X, y, target_class, n_samples=100, noise_factor=0.05):\n",
        "    \"\"\"\n",
        "    Augmentation de données pour une classe spécifique\n",
        "    Génère de nouveaux échantillons en ajoutant du bruit gaussien\n",
        "    \"\"\"\n",
        "    class_mask = y == target_class\n",
        "    class_samples = X[class_mask]\n",
        "\n",
        "    if len(class_samples) == 0:\n",
        "        return np.array([]), np.array([])\n",
        "\n",
        "    # Génération de nouveaux échantillons\n",
        "    augmented = []\n",
        "    labels = []\n",
        "\n",
        "    for _ in range(n_samples):\n",
        "        # Sélection aléatoire d'un échantillon de base\n",
        "        idx = np.random.randint(0, len(class_samples))\n",
        "        base_sample = class_samples[idx]\n",
        "\n",
        "        # Ajout de bruit gaussien\n",
        "        noise = np.random.normal(0, noise_factor, base_sample.shape)\n",
        "        new_sample = base_sample + noise\n",
        "\n",
        "        augmented.append(new_sample)\n",
        "        labels.append(target_class)\n",
        "\n",
        "    return np.array(augmented), np.array(labels)\n",
        "\n",
        "print(\"🔄 Préparation de l'augmentation pour Question 3...\")\n",
        "# Cette fonction sera utilisée lors de la préparation des données par question"
      ]
    },
